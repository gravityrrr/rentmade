<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FF090B12"
                android:centerColor="#FF0D1220"
                android:endColor="#FF07090E" />
        </shape>
    </item>
    <item android:top="-180dp" android:left="-120dp" android:right="120dp" android:bottom="420dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="360dp"
                android:centerX="0.25"
                android:centerY="0.15"
                android:startColor="#33D6B46D"
                android:endColor="#00090B12" />
        </shape>
    </item>
    <item android:top="220dp" android:left="80dp" android:right="-120dp" android:bottom="-300dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="420dp"
                android:centerX="0.8"
                android:centerY="0.75"
                android:startColor="#2266D9EF"
                android:endColor="#00090B12" />
        </shape>
    </item>
</layer-list>
