<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Card Styles -->
    <style name="Widget.Made.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="strokeColor">@color/colorStroke</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>
    <style name="Widget.Made.Card.Glow" parent="Widget.Made.Card">
        <item name="strokeColor">@color/colorNeonStroke</item>
    </style>
    <style name="Widget.Made.Card.Elevated" parent="Widget.Made.Card">
        <item name="cardBackgroundColor">@color/colorSurfaceVariant</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.Made.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_body_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="backgroundTint">@color/colorPrimary</item>
    </style>
    <style name="Widget.Made.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/colorSecondary</item>
        <item name="android:textSize">@dimen/text_body_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="backgroundTint">@color/colorSuccessBg</item>
    </style>
    <style name="Widget.Made.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textSize">@dimen/text_body_md</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Text Input Style -->
    <style name="Widget.Made.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/colorSurfaceVariant</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="boxStrokeColor">@color/colorStroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/colorTextMuted</item>
        <item name="android:textColorHint">@color/colorTextMuted</item>
    </style>

    <!-- Text Appearances -->
    <style name="TextAppearance.Made.HeadlineXL">
        <item name="android:textSize">@dimen/text_headline_xl</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Made.HeadlineLg">
        <item name="android:textSize">@dimen/text_headline_lg</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Made.HeadlineMd">
        <item name="android:textSize">@dimen/text_headline_md</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.Made.BodyLg">
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
    </style>
    <style name="TextAppearance.Made.BodyMd">
        <item name="android:textSize">@dimen/text_body_md</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>
    <style name="TextAppearance.Made.BodySm">
        <item name="android:textSize">@dimen/text_body_sm</item>
        <item name="android:textColor">@color/colorTextMuted</item>
    </style>
    <style name="TextAppearance.Made.Label">
        <item name="android:textSize">@dimen/text_label_md</item>
        <item name="android:textColor">@color/colorTextMuted</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
    <style name="TextAppearance.Made.MonoLg">
        <item name="android:textSize">@dimen/text_mono_lg</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.Made.MonoXL">
        <item name="android:textSize">@dimen/text_mono_xl</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Status Pill Styles -->
    <style name="Widget.Made.Pill">
        <item name="android:textSize">@dimen/text_body_sm</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingStart">@dimen/pill_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/pill_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/pill_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/pill_padding_vertical</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="Widget.Made.Pill.Paid" parent="Widget.Made.Pill">
        <item name="android:background">@drawable/bg_status_pill_paid</item>
        <item name="android:textColor">@color/colorSuccess</item>
    </style>
    <style name="Widget.Made.Pill.Pending" parent="Widget.Made.Pill">
        <item name="android:background">@drawable/bg_status_pill_pending</item>
        <item name="android:textColor">@color/colorWarning</item>
    </style>
    <style name="Widget.Made.Pill.Overdue" parent="Widget.Made.Pill">
        <item name="android:background">@drawable/bg_status_pill_overdue</item>
        <item name="android:textColor">@color/colorError</item>
    </style>
    <style name="Widget.Made.Pill.Verified" parent="Widget.Made.Pill">
        <item name="android:background">@drawable/bg_status_pill_verified</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>
</resources>
